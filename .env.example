# ── Exchange Credentials ─────────────────────────────────────────────────────
# Binance mainnet (read-only; not required for public OHLCV data)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# Binance Spot Testnet — obtain free keys at https://testnet.binance.vision/
# NEVER paste real keys here. This file IS committed to git.
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_SECRET_KEY=your_testnet_secret_key_here

# ── AI / LLM Backend ─────────────────────────────────────────────────────────
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:latest

# ── Application Settings ─────────────────────────────────────────────────────
# Set to "development" | "staging" | "production"
APP_ENV=development

# ── Risk Management ──────────────────────────────────────────────────────────
MAX_POSITION_SIZE_USDT=100.0
MAX_DRAWDOWN_PERCENT=5.0

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
